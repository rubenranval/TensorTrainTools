Notebook[{

Cell[CellGroupData[{
Cell["RandomTensorTrain", "ObjectName",
 CellID->460466061,ExpressionUUID->"6e309cfc-70e5-2040-86a6-feb082dbee7d"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"db1564f5-0ce3-2a49-a688-a59d4e3c009d"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["RandomTensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/RandomTensorTrain"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["n", "TI"], 
      StyleBox["1", "TR"]], ",", " ", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     StyleBox["nd", "TI"]}], "}"}], "]"}]], "InlineFormula",ExpressionUUID->
  "59e7b16a-c290-3646-92de-7ea5ecec091e"],
 "\[LineSeparator]gives a random tensor train representing a tensor of \
dimensions n1*...*nd. \n",
 Cell["   ", "ModInfo",ExpressionUUID->"11648a7f-cef1-e84c-ae37-c7a6a6fa6a75"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["RandomTensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/RandomTensorTrain"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["n", "TI"], 
       StyleBox["1", "TR"]], ",", " ", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      StyleBox["nd", "TI"]}], "}"}], ",", 
    StyleBox["chi", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "0245824d-5290-9845-a8d5-70fd18f12284"],
 "\[LineSeparator]sets every bond dimension to chi; \n",
 Cell["   ", "ModInfo",ExpressionUUID->"5022523b-6144-7042-af36-93d07f38ba34"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["RandomTensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/RandomTensorTrain"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["n", "TI"], 
       StyleBox["1", "TR"]], ",", " ", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      StyleBox["nd", "TI"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["chi", "TI"], 
       StyleBox["1", "TR"]], ",", " ", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      RowBox[{
       StyleBox["chi", "TI"], 
       RowBox[{"(", 
        RowBox[{
         StyleBox["d", "TI"], "-", "1"}], ")"}]}]}], "}"}]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"8a41ee1a-7c9e-e447-9463-c849b892c2b1"],
 "\[LineSeparator]sets the bonds individually. Cores are filled with random \
reals in [-1, 1]; the option ",
 Cell[BoxData[
  RowBox[{"\"\<Complex\>\"", "->", 
   ButtonBox["True",
    BaseStyle->"Link"]}]], "InlineFormula",ExpressionUUID->
  "1907bf40-c3c6-af44-8a9b-4079debaa822"],
 " fills them with random complex entries instead."
}], "Usage",
 CellChangeTimes->{{3.992416194560543*^9, 3.992416195068552*^9}},
 CellID->346567193,ExpressionUUID->"9ad79242-210f-fb42-93d4-42568bfb78d0"],

