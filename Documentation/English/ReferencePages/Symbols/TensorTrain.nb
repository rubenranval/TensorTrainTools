Cell["Construct a tensor train from two explicit cores:", "ExampleText",
 CellChangeTimes->{{3.993278794573803*^9, 3.9932788048050556`*^9}},
 CellID->248028504,ExpressionUUID->"260d5740-2720-9845-a6a5-0d95be528c07"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cores", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], ",", " ", 
       RowBox[{"{", 
