Notebook[{

Cell[CellGroupData[{
Cell["TensorTrain", "ObjectName",
 CellID->182993948,ExpressionUUID->"6fd722ef-c718-5946-89da-400267a4c52f"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"726ea51b-a2e0-6e49-a5cd-a898d1a4d579"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrain"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", " ", 
     SubscriptBox["A", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["A", "n"]}], "}"}], "]"}]], "InlineFormula",
  InitializationCell->True,ExpressionUUID->
  "bb64f274-7853-3541-ae78-1fe296d952ae"],
 "\[LineSeparator]represents a tensor in tensor train format with rank-3 \
cores ",
 Cell[BoxData[
  SubscriptBox["A", "i"]], "InlineFormula",ExpressionUUID->
  "9f5c9d68-252b-ff4e-a5a8-c4680551948d"]
}], "Usage",
 CellChangeTimes->{
  3.9924161964502907`*^9, {3.992416569224495*^9, 3.9924165960356827`*^9}, {
   3.9932814603999023`*^9, 3.9932815293633175`*^9}, 3.9933882526173115`*^9},
 CellID->847066822,ExpressionUUID->"e210f328-074d-d049-9029-4dbd5e6a1df0"],

Cell[TextData[{
 "A tensor train (also called a matrix product state, MPS) expresses a tensor \
of rank ",
 Cell[BoxData[
 "n"], "InlineFormula",ExpressionUUID->"babf28ee-ea82-124a-9beb-c57a6bda6376"],
 " as a chain of ",
 Cell[BoxData[
 "n"], "InlineFormula",ExpressionUUID->"3c4a6560-1e22-f547-bea0-10b10d4110b5"],
 " rank-3 cores, typically storing far fewer elements than the dense tensor."
}], "Notes",
 CellChangeTimes->{3.992416602737192*^9},
 CellID->320248012,ExpressionUUID->"9d2c330b-fd22-3a41-8777-e761ab948018"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  SubscriptBox["A", "i"]], "InlineFormula",ExpressionUUID->
  "e8819161-5590-2340-8a77-4f55c3016932"],
 " must be a rank-3 array with dimensions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox["\[Chi]", 
     RowBox[{"i", "-", "1"}]], ",", 
    SubscriptBox["n", "i"], ",", 
    SubscriptBox["\[Chi]", "i"]}], "}"}]], "InlineFormula",ExpressionUUID->
  "74e2ce54-758f-f744-b44a-78201426cd5e"],
 ", where ",
 Cell[BoxData[
  SubscriptBox["n", "i"]], "InlineFormula",ExpressionUUID->
  "e7be54eb-0761-024e-b22e-d43dff7b24a5"],
 " is the ",
 Cell[BoxData[
  SuperscriptBox["i", "th"]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "913c55aa-8471-0d4b-8100-0e3996e0594f"],
 " dimension of the represented tensor and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "i"]], "InlineFormula",ExpressionUUID->
  "fb2731f5-3966-e645-8adb-edd6cb1c3fb3"],
 " are the bond dimensions."
}], "Notes",
 CellChangeTimes->{{3.993277525531929*^9, 3.99327754901746*^9}},
 CellID->23113461,ExpressionUUID->"02541b8d-3fa4-c44f-bbdd-a0bbb252204a"],

Cell[TextData[{
 "The boundary bond dimensions ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "0"]], "InlineFormula",ExpressionUUID->
  "7b6a8b03-659e-d841-ad05-c3b7f5bfbc3e"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "n"]], "InlineFormula",ExpressionUUID->
  "0c195e48-1e84-7f46-a6a1-40d7bb6312c7"],
 " must both equal 1, and the last dimension of each core must equal the \
first dimension of the following core."
}], "Notes",
 CellID->276603418,ExpressionUUID->"6ac1771b-4dbf-864a-9701-f89b93cd73d2"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["TensorTrain",
   BaseStyle->"Link",
   ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"]], 
  "InlineFormula",ExpressionUUID->"77eed437-570a-ab4b-86f9-a03714a65a68"],
 " validates its cores, issuing a message and returning ",
 Cell[BoxData[
  ButtonBox["$Failed",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "4066207f-d697-0443-8676-530f7e6bb5f8"],
 " if they do not form a valid tensor train."
}], "Notes",
 CellChangeTimes->{{3.993277519113199*^9, 3.993277519113199*^9}, {
  3.993277614577677*^9, 3.993277614577677*^9}},
 CellID->172931060,ExpressionUUID->"60b697a4-4a66-dd47-94f5-275c5b27194a"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["TensorTrain",
     BaseStyle->"Link",
     ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"], "[", 
    "\[Ellipsis]", "]"}], "[", "\"\<Properties\>\"", "]"}]], "InlineFormula",
  ExpressionUUID->"fb1e30fc-2604-7547-a707-6331eb0b599f"],
 " gives a list of all available properties."
}], "Notes",
 CellChangeTimes->{{3.993277511671131*^9, 3.993277511671131*^9}},
 CellID->77529935,ExpressionUUID->"77555c97-f7ca-3843-9ae5-37135a6b8d9a"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "4a2b72af-877c-5e4b-8991-b631e2d939c8"], "\"\<Cores\>\"", Cell[
    "the list of rank-3 cores", "TableText",ExpressionUUID->
     "8aa40320-82a3-d440-a956-8551b4554683"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "9b2b34b4-8c18-7243-981a-812d1fce7510"], "\"\<CoreCount\>\"", Cell[
    "the number of cores", "TableText",ExpressionUUID->
     "977b8684-07fc-0240-9b21-870ac061dd49"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "16b4dd48-dc7b-3d47-904b-06dee43d2bcb"], "\"\<TensorDimensions\>\"", 
    Cell["the dimensions of the original tensor", "TableText",ExpressionUUID->
     "c0188c1b-71cf-ec41-bbc7-1bd616eba704"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "d0d749c7-540d-d04b-8df3-314f47db8a58"], "\"\<BondDimensions\>\"", Cell[
    "the internal bond dimensions of the tensor train", "TableText",
     ExpressionUUID->"67730e40-f911-b44d-b7d9-65fa86b64817"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "e23efa5d-af47-c948-abf6-5a30ac538e1f"], "\"\<ParameterCount\>\"", Cell[
    "the total number of stored core elements", "TableText",ExpressionUUID->
     "27a521d7-08f8-e14f-a5b8-cc4414557637"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "cff37cd3-defd-7a4c-92af-7e62f162c2bd"], "\"\<FullElementCount\>\"", 
    Cell["the number of elements of the represented dense tensor", 
     "TableText",ExpressionUUID->"82de0370-8141-274a-b383-33e176c81567"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "07d9a39d-6204-9f40-a823-fbca091db6e7"], "\"\<CompressionRatio\>\"", 
    Cell["ratio of dense element count to stored paramater count", 
     "TableText",ExpressionUUID->"3ff9a794-4f01-7b4e-9722-07842451b8b5"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ae9131da-dce1-9a4d-8a52-cbf396235cba"], "\"\<Tensor\>\"", Cell[
    "the original input tensor", "TableText",ExpressionUUID->
     "d7a559d2-f950-014b-ae4d-29bbf8b6fa85"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "17c216d1-a7de-e74f-b59f-3785375bb250"], "\"\<Diagram\>\"", Cell[
    "a tensor network diagram of the train", "TableText",ExpressionUUID->
     "0b08f608-1fdf-054d-a34c-95f2452fcb9a"]}
  }]], "2ColumnTableMod",
 CellChangeTimes->{{3.9932773149434223`*^9, 3.993277427449827*^9}, {
  3.993278036297779*^9, 3.9932781640434055`*^9}},
 CellID->742480866,ExpressionUUID->"d4d9b12f-83db-0a49-beca-80771c69154e"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Normal",
     BaseStyle->"Link"], "[", 
    RowBox[{
     ButtonBox["TensorTrain",
      BaseStyle->"Link",
      ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"], "[",
      "\[Ellipsis]", "]"}], "]"}], " "}]], "InlineFormula",ExpressionUUID->
  "2b6f888e-ad7f-5641-ba7f-a77238d7301f"],
 "gives the represented tensor as a dense array, contracting all bond \
indices. It is equivalent to ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainContract",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainContract"], "[", 
   RowBox[{
    ButtonBox["TensorTrain",
     BaseStyle->"Link",
     ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"], "[", 
    "\[Ellipsis]", "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "34c8be39-59c6-474f-a5d0-1570d4332229"],
 "."
}], "Notes",
 CellChangeTimes->{{3.9932781878454857`*^9, 3.993278269266775*^9}, {
  3.993279273157198*^9, 3.9932793265686073`*^9}},
 CellID->277942910,ExpressionUUID->"9012537d-b02d-1f43-87e1-c6441df935b0"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["Length",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "66064267-c9a9-c54e-a025-84882dc9fcc7"],
 "[",
