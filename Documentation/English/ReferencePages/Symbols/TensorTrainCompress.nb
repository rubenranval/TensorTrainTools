Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainCompress", "ObjectName",
 CellID->32514204,ExpressionUUID->"bda49d1a-cf42-7246-8dc4-40b3f2b35968"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"3edb6ef0-cd45-0243-84e4-723eb3bba1b5"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainCompress",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainCompress"],
    "[", 
   ButtonBox["TensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "0cafdf23-824c-a045-b919-9b0025ba3b3f"],
 "\[LineSeparator]returns a tensor train approximating ",
 Cell[BoxData[
  ButtonBox["TensorTrain",
   BaseStyle->"Link",
   ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"]], 
  "InlineFormula",ExpressionUUID->"05da84f3-d44d-be49-bd3e-560bd05fccab"],
 " with smaller bond dimensions, by right-orthogonalizing and then truncating \
each bond with an SVD sweep. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Tolerance",
    BaseStyle->"Link"], "->", "eps"}]], "InlineFormula",ExpressionUUID->
  "f161d4d8-16d2-a144-afbb-d7fdec75c444"],
 " discards the smallest singular values whose total squared weight stays \
below eps^2 at each bond; ",
 Cell[BoxData[
  RowBox[{"\"\<MaxBondDimension\>\"", "->", "r"}]], "InlineFormula",
  ExpressionUUID->"1f41e0a9-26a0-9543-a16d-9c0876c5e50a"],
 " caps every bond at r. ",
 Cell[BoxData[
  ButtonBox["With",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "fc284ac8-d5f3-3c45-b2fe-8afd0278ba6a"],
 " the defaults ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", "Tolerance"}], "->", "0"}]], "InlineFormula",ExpressionUUID->
  "f15229ff-b922-574f-9399-46eaf9478b35"],
 ", ",
 Cell[BoxData[
  RowBox[{"\"\<MaxBondDimension\>\"", "->", 
   RowBox[{"Infinity", ")"}]}]], "InlineFormula",ExpressionUUID->
  "e4e6b61d-b24f-1e4a-a9c4-e4a8cb5640d2"],
 " only exact-zero singular values are removed, so redundant ranks collapse \
losslessly."
}], "Usage",
 CellChangeTimes->{{3.9924161975478745`*^9, 3.9924161982800446`*^9}},
 CellID->132223813,ExpressionUUID->"6e37a50a-1178-c84e-b58a-90ec5ed71ffa"],

Cell["The following options can be given: ", "Notes",
 CellID->123761334,ExpressionUUID->"7dad22b3-656e-a245-96e1-f36a00849ea7"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "b0949e22-5acb-fe48-a061-3409148ee6e6"], "\"\<MaxBondDimension\>\"", 
    ButtonBox["Infinity",
     BaseStyle->"Link"], Cell[
    "XXXX", "TableText",ExpressionUUID->
     "694bbf6e-34d8-d343-b8af-81d896ec7a38"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "48c3a117-e183-6345-9917-8b36bd06c617"], 
    ButtonBox["Tolerance",
     BaseStyle->"Link"], "0", Cell[
    "XXXX", "TableText",ExpressionUUID->
     "cca46898-f8e5-0440-9265-715a2d130d59"]}
  }]], "3ColumnTableMod",
 CellID->769451305,ExpressionUUID->"f0a26347-a205-5049-9a18-8dc4c5ffc3e2"]
}, Open  ]],

