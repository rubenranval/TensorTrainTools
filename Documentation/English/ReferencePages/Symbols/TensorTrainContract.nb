Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainContract", "ObjectName",
 CellID->479105082,ExpressionUUID->"ecf6c7b9-a37b-5745-8cb7-863aa133c436"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"28047d74-e319-174e-87cf-c35abb9f436c"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainContract",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainContract"],
    "[", 
   StyleBox["tt", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "acce7261-cdcd-1a45-a96d-eef2f56790a5"],
 "\[LineSeparator]contracts a tensor train (a ",
 Cell[BoxData[
  ButtonBox["TensorTrain",
   BaseStyle->"Link",
   ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"]], 
  "InlineFormula",ExpressionUUID->"d8aedaa1-1da2-ce43-a32d-46ed690d74c1"],
 " object, or a list of rank-3 cores ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8d42850d-c817-7340-b2fc-bc63e8bfbee7"],
 ") into the dense array it represents."
}], "Usage",
 CellChangeTimes->{3.9924151977008266`*^9, 3.992415521749195*^9},
 CellID->57742026,ExpressionUUID->"806d3126-2c35-8440-a658-5b3e850ab859"],

Cell[TextData[{
 Cell[BoxData["TensorTrainContract"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "94981270-fb27-3841-b084-bfa885545b23"],
 " reconstructs a full dense array from its Tensor Train (TT) representation \
(also known as the Matrix Product State representation). It is the inverse of \
",
 Cell[BoxData[
  ButtonBox["TensorTrainDecomposition",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition"]], 
  "InlineFormula",ExpressionUUID->"11e7df6e-8c6e-ad4a-8347-0a5abe324ee9"],
 "."
}], "Notes",
 CellChangeTimes->{
  3.992415534765217*^9, {3.992415574617302*^9, 3.992415592593235*^9}},
 CellID->10691157,ExpressionUUID->"51cc526c-4842-2e45-848a-9d9c65ce6e1c"],

Cell[TextData[{
 "The input is a nonempty list of rank-3 arrays ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f43cf35-4f22-f545-b45e-c58b075e3bc8"],
 ", where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d9fbcdd9-e2cd-1447-9c4d-c930ce1625ce"],
 " is the number of dimensions of the resulting array."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.990777688228838*^9, 3.9907777001446056`*^9}, 
   3.990779220673212*^9},
 CellID->532595843,ExpressionUUID->"c412f35c-dce7-8b4c-8369-f7cd719ee071"],

Cell["\<\
The bond dimension refers to the size of the internal contracted indices \
connecting adjacent tensor cores. It effectively dictates the rank and \
compression level of the Tensor Train.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.990800740947536*^9, 3.990800743146851*^9}, {
  3.99080080940193*^9, 3.990800811294792*^9}},
 CellID->362833641,ExpressionUUID->"874497f5-f3d6-554a-ab56-ad9023995598"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "e4ac3223-370b-0341-97af-b9bb63750809"],
 " has dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Chi]", 
      RowBox[{"k", "-", "1"}]], ",", 
     SubscriptBox["d", "k"], ",", 
     SubscriptBox["\[Chi]", "k"]}], "}"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "92fcbb33-6ab3-e349-894d-c82ab7121c83"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "k"], TraditionalForm]],ExpressionUUID->
  "aadcb5bf-171d-a244-b876-2a40b3e8d153"],
 " is the size of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "418b2e0c-2dcc-6f44-af5c-1c286d2c6b99"],
 " dimension of the resulting array, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "k"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "9f57407d-7425-fc4b-a0d6-26bc35f8c729"],
 " is the bond dimension between cores ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d327666-5c26-f94c-b8b4-6c67a7dfb2e0"],
 " and",
 Cell[BoxData[
  RowBox[{
   StyleBox["k", "TI"], "+", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b8b8c555-15a0-7d4b-8983-904d8c204102"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9907796982123947`*^9, 3.990779701919855*^9}, {
  3.990800884052023*^9, 3.99080089280112*^9}},
 CellID->534729610,ExpressionUUID->"14f82288-d56e-0c45-91bf-d971f6553090"],

Cell[TextData[{
 "The first core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "ac47dafa-7e2b-1c45-ad03-2989710361cb"],
 " and the last core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "n"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "4c4fb5e8-d8b3-ee40-bc18-ed9b58049054"],
 "."
}], "Notes",
 TaggingRules->{},
 CellID->57498604,ExpressionUUID->"87bea6b7-d66b-0d4a-9505-547227d0cecd"],

Cell[TextData[{
 "Contracting the cores returned by ",
 Cell[BoxData[
  ButtonBox["TensorTrainDecomposition",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition"]], 
  "InlineFormula",ExpressionUUID->"9835831c-a564-194e-97b9-1dcb0097c6c6"],
 " reconstructs the original array, exactly up to floating-point error when \
the decomposition was exact, or up to the truncation error when a ",
 Cell[BoxData["\"\<MaxBondDimension\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6874d734-b58c-9c48-909d-2f046f81d27d"],
 " cap or nonzero ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Tolerance", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Tolerance",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d9eb0de2-872e-a549-b4e0-545ec5680db1"],
 " was applied."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9907779127790375`*^9, 3.9907779295900173`*^9}, 
   3.9918222070023003`*^9, {3.992415604659996*^9, 3.992415608027321*^9}},
 CellID->13324534,ExpressionUUID->"6a8cf01d-0c15-1741-b0c2-fb01a4201f39"]
}, Open  ]],

