Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["TensorTrain",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            TagBox[
             GraphicsBox[
              NamespaceBox["NetworkGraphics", 
               DynamicModuleBox[{Typeset`graph = HoldComplete[
                   
                   Graph[{"c1", "c2", "c3", "p1", "p2", "p3"}, {
                    Null, {{1, 2}, {2, 3}, {1, 4}, {2, 5}, {3, 6}}}, {
                    EdgeLabels -> {None}, EdgeStyle -> {
                    Directive[
                    Thickness[Large], 
                    GrayLevel[0.4]]}, ImageSize -> {Automatic, 40}, 
                    PlotRangePadding -> 0.3, 
                    VertexCoordinates -> {{1, 0}, {2, 0}, {3, 0}, {1, -0.8}, {
                    2, -0.8}, {3, -0.8}}, VertexLabels -> {None}, 
                    VertexSize -> {
                    "p2" -> 0.01, "p1" -> 0.01, "c1" -> 0.5, "p3" -> 0.01, 
                    "c2" -> 0.5, "c3" -> 0.5}, 
                    VertexStyle -> {
                    "p1" -> GrayLevel[0.5], "p2" -> GrayLevel[0.5], "c1" -> 
                    RGBColor[0.35, 0.55, 0.85], "c2" -> 
                    RGBColor[0.35, 0.55, 0.85], "p3" -> GrayLevel[0.5], "c3" -> 
                    RGBColor[0.35, 0.55, 0.85]}}]]}, 
                TagBox[
                 GraphicsGroupBox[{{
                    Directive[
                    Opacity[0.7], 
                    Hue[0.6, 0.7, 0.7], 
                    CapForm["Round"]], 
                    Directive[
                    Thickness[Large], 
                    GrayLevel[0.4]], 
                    LineBox[{{
                    DynamicLocation["VertexID$1", Automatic, Center], 
                    DynamicLocation["VertexID$2", Automatic, Center]}, {
                    DynamicLocation["VertexID$1", Automatic, Center], 
                    DynamicLocation["VertexID$4", Automatic, Center]}, {
                    DynamicLocation["VertexID$2", Automatic, Center], 
                    DynamicLocation["VertexID$3", Automatic, Center]}, {
                    DynamicLocation["VertexID$2", Automatic, Center], 
                    DynamicLocation["VertexID$5", Automatic, Center]}, {
                    DynamicLocation["VertexID$3", Automatic, Center], 
                    DynamicLocation["VertexID$6", Automatic, Center]}}]}, {
                    Directive[
                    Hue[0.6, 0.5, 1.], 
                    EdgeForm[
                    Directive[
                    GrayLevel[0], 
                    Opacity[0.7]]]], 
                    TagBox[
                    StyleBox[
                    DiskBox[{1., 0.}, 0.2], {
                    RGBColor[0.35, 0.55, 0.85]}, StripOnInput -> False], 
                    "DynamicName", BoxID -> "VertexID$1"], 
                    TagBox[
                    StyleBox[
                    DiskBox[{2., 0.}, 0.2], {
                    RGBColor[0.35, 0.55, 0.85]}, StripOnInput -> False], 
                    "DynamicName", BoxID -> "VertexID$2"], 
                    TagBox[
                    StyleBox[
                    DiskBox[{3., 0.}, 0.2], {
                    RGBColor[0.35, 0.55, 0.85]}, StripOnInput -> False], 
                    "DynamicName", BoxID -> "VertexID$3"], 
                    TagBox[
                    StyleBox[
                    DiskBox[{1., -0.8}, 0.004], {
                    GrayLevel[0.5]}, StripOnInput -> False], "DynamicName", 
                    BoxID -> "VertexID$4"], 
                    TagBox[
                    StyleBox[
                    DiskBox[{2., -0.8}, 0.004], {
                    GrayLevel[0.5]}, StripOnInput -> False], "DynamicName", 
                    BoxID -> "VertexID$5"], 
                    TagBox[
                    StyleBox[
                    DiskBox[{3., -0.8}, 0.004], {
                    GrayLevel[0.5]}, StripOnInput -> False], "DynamicName", 
                    BoxID -> "VertexID$6"]}}], 
                 MouseAppearanceTag["NetworkGraphics"]], 
                AllowKernelInitialization -> False]], {
              FormatType -> TraditionalForm, FrameTicks -> None, 
               ImageSize -> {Automatic, 40}, PlotRangePadding -> 0.3, 
               DefaultBaseStyle -> "NetworkGraphics"}], Deploy, 
             DefaultBaseStyle -> "Deploy"], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Cores: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["3", "SummaryItem"]}]}, {
               RowBox[{
