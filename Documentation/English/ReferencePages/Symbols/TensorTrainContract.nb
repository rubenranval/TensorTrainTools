Cell["\<\
Because contraction works on any valid train, you can decompose with a capped \
bond dimension and contract the result to obtain a low-rank approximation of \
the original tensor. The difference is the truncation error:\
\>", "ExampleText",
 CellChangeTimes->{3.992415767182045*^9},
 CellID->669699521,ExpressionUUID->"d917eede-e982-2e46-8f4b-8435f5ebacac"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"largeTensor", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "4", ",", "4", ",", "4"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"compressed", "=", 
    RowBox[{"TensorTrainDecomposition", "[", 
     RowBox[{"largeTensor", ",", 
      RowBox[{"\"\<MaxBondDimension\>\"", "->", "2"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"approx", "=", 
   RowBox[{"TensorTrainContract", "[", "compressed", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Max", "[", 
  RowBox[{"Abs", "[", 
   RowBox[{"largeTensor", "-", "approx"}], "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9924157778315945`*^9, 3.9924157996762276`*^9}},
 CellLabel->"In[259]:=",
 CellID->436603722,ExpressionUUID->"f671edfe-c199-b34c-adc1-65a0725c2630"],

