Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainDecomposition", "ObjectName",
 CellID->141156892,ExpressionUUID->"b3b2a298-df07-4040-9b20-338d8b86de42"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"f7fa70e5-9064-0941-a349-b2d4d8fa7526"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainDecomposition",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanvalTensorTrainTools/ref/TensorTrainDecomposition"], "[", 
   StyleBox["tensor", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "c27879e6-ae75-8a4c-9863-4bc4e46032d6"],
 "\[LineSeparator]decomposes the numeric array tensor into a tensor train, a \
list of rank-3 cores ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]],
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "426a4e63-8fa1-174b-8f0b-cc8478195ae8"],
 "."
}], "Usage",
 CellChangeTimes->{
  3.9924132469778996`*^9, {3.992413299171282*^9, 3.9924133015594234`*^9}, 
   3.9924133684296246`*^9},
 CellID->174850504,ExpressionUUID->"1ab59a36-ead3-c043-90c7-1d86ba931d2f"],

Cell["\<\
TensorTrainDecomposition decomposes a numerical array of any rank into a \
Tensor Train (also known as a Matrix Product State) representation.\
\>", "Notes",
 TaggingRules->{},
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellChangeTimes->{{3.9870676396219063`*^9, 3.9870676860003395`*^9}, {
  3.9870912910091953`*^9, 3.987091293314743*^9}, {3.987091444078535*^9, 
  3.9870914584316254`*^9}, {3.987091838714548*^9, 3.9870918553230457`*^9}, {
  3.9870938483814526`*^9, 3.987093849361397*^9}},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->440071331,ExpressionUUID->"17f30a25-f74b-3f46-bb1b-26c9a8adf599"],

Cell[TextData[{
 "The result is a list of rank-3 arrays ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f0e6bd9a-fbd9-ed4e-a725-2c8ae6f245f5"],
 " where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8af1e544-1872-6d46-9ee2-360ca6c82e0f"],
 " is the number of dimensions of the input tensor."
}], "Notes",
 TaggingRules->{},
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellChangeTimes->{{3.9870676396219063`*^9, 3.9870676860003395`*^9}, {
  3.9870677310102386`*^9, 3.98706773582288*^9}, {3.9870677678360023`*^9, 
  3.987067873939348*^9}, {3.9870701917686214`*^9, 3.987070208580799*^9}, {
  3.987086879624007*^9, 3.987086889072908*^9}},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->364261975,ExpressionUUID->"d47b004c-ea25-9348-b286-ebd8ab71c5fd"],

Cell["\<\
The bond dimension refers to the size of the internal contracted indices \
connecting adjacent tensor cores. It effectively dictates the rank and \
compression level of the Tensor Train.\
\>", "Notes",
 TaggingRules->{},
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellChangeTimes->{{3.9870676396219063`*^9, 3.9870676860003395`*^9}, {
  3.9870677310102386`*^9, 3.98706773582288*^9}, {3.9870677678360023`*^9, 
  3.987067873939348*^9}, {3.9870701917686214`*^9, 3.987070208580799*^9}, {
  3.987086879624007*^9, 3.987086889072908*^9}, {3.9870893260195923`*^9, 
  3.987089368464039*^9}, {3.9870914897072277`*^9, 3.9870914898097706`*^9}, {
  3.98709182361454*^9, 3.9870918319188156`*^9}},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->27814531,ExpressionUUID->"61744e5d-3a9f-c84a-a551-265509706411"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "366f08bb-29d6-6b43-a45c-16be312cc9b7"],
 " has dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Chi]", 
      RowBox[{"k", "-", "1"}]], ",", 
     SubscriptBox["d", "k"], ",", 
     SubscriptBox["\[Chi]", "k"]}], "}"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "460905b4-17d1-a64e-a7bf-bb773c688b33"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "k"], TraditionalForm]],ExpressionUUID->
  "0ecf4b45-e5b3-a740-8e59-86ac419e47a3"],
 " is the size of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "e9903cde-061f-7e40-b710-da9ac2a75603"],
 " dimension of the input tensor, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "k"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "aa6193be-801a-5b44-ad32-b647e67dd56d"],
 " is the bond dimension between cores k and k+1."
}], "Notes",
 TaggingRules->{},
 InitializationCell->True,
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellChangeTimes->{{3.9870676396219063`*^9, 3.9870676860003395`*^9}, {
  3.9870679016213875`*^9, 3.98706802704377*^9}},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->614074359,ExpressionUUID->"9329994b-93c2-6d48-823e-ca3f7994c522"],

Cell[TextData[{
 "The first core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "1575ab9c-5817-5f48-ac5c-3b73cb618f7c"],
 " and the last core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "n"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "f86b3f3a-6ed5-3e4b-a1d7-7da2887c436d"],
 "."
}], "Notes",
