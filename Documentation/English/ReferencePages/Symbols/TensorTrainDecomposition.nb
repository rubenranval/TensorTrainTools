     BaseStyle->"Link"], Cell[
    "maximum bond dimension \[Chi] at each core", "TableText",ExpressionUUID->
     "832ce482-0c03-9541-922e-9b7ff8386779"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "31db6b11-4de1-094e-a3dd-ddfad2f7958a"], 
