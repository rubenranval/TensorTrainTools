       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/SingularValueDecomposition",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bf7cb145-3b0a-f84f-97ea-f285d5e8ff4b"],
 " to attempt symbolic root-finding. For large matrices, this scales \
exponentially:"
}], "ExampleText",
 CellChangeTimes->{3.9924143045794964`*^9},
 CellID->172963048,ExpressionUUID->"57269847-924b-864a-810c-fc5e11573839"],

