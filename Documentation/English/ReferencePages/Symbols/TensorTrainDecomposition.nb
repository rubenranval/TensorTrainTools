  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.9924134811636868`*^9, 3.9924135055037766`*^9}},
 CellID->814621413,ExpressionUUID->"989b7d97-4fb3-2a40-8efb-b267ad914b3a"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Method", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Method",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "21d6d624-2667-624d-bdcd-aec420168dd6"],
 " \[RightArrow] \"QR\", the function ignores \"MaxBondDimension\" and ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["Tolerance", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/Tolerance",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "90ece238-c640-e94c-b4b6-c58024e6106c"],
 " and returns the exact decomposition. ",
 Cell[BoxData[
  TagBox[
   ButtonBox[
    StyleBox["QRDecomposition", "SymbolsRefLink",
     ShowStringCharacters->True,
     FontFamily->"Source Sans Pro"],
    BaseStyle->Dynamic[
      FEPrivate`If[
       CurrentValue["MouseOver"], {
       "Link", FontColor -> RGBColor[0.8549, 0.39608, 0.1451]}, {"Link"}]],
    ButtonData->"paclet:ref/QRDecomposition",
    ContentPadding->False],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54d96de6-a7e0-bd46-9fb9-159804a757cf"],
 " does not provide singular values, so truncation is not available."
}], "Notes",
 TaggingRules->{},
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
