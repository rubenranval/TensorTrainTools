 CellTags->{"DefaultContent", "TabNext"},
 CellID->566266086,ExpressionUUID->"27710b8d-8b5f-d341-afd5-5042f8e77757"],

Cell["The following options can be given: ", "Notes",
 CellID->128458998,ExpressionUUID->"62eae5da-0ba8-324c-912f-825f3d4df9c4"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "9a58fff5-e52c-cb4e-bf9b-606c8ff04992"], "\"\<MaxBondDimension\>\"", 
