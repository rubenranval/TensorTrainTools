Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Neat Examples", "ExampleSection",ExpressionUUID->
   "0be75878-b8c0-8941-a503-9e338325d5af"],
  $Line = 0; Null]], "ExampleSection",
 CellID->101886849,ExpressionUUID->"39440780-7ec7-1b4d-b68c-3c685d767c81"],

Cell["\<\
Reconstruct a non-separable pattern from tensor trains of increasing bond \
dimension to watch a low-rank approximation sharpen into the exact array:\
\>", "ExampleText",
 CellChangeTimes->{3.9924146702279835`*^9},
 CellID->294162820,ExpressionUUID->"44a06b85-3360-0446-858a-43c3ad2c23de"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "120"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"n", "+", "1"}], ")"}], "/", "2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pattern", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      FractionBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"i", "-", "c"}], ")"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"j", "-", "c"}], ")"}], "2"]}], "]"}], "4."], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "n"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ranks", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", " ", "5", ",", "20", ",", "30"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"recons", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"TensorTrainContract", "[", 
      RowBox[{"TensorTrainDecomposition", "[", 
       RowBox[{"pattern", ",", 
        RowBox[{"\"\<MaxBondDimension\>\"", "->", "r"}]}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "ranks"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Row", "[", 
  RowBox[{"MapThread", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ArrayPlot", "[", 
      RowBox[{"#1", ",", 
       RowBox[{"ColorFunction", "->", "\"\<DeepSeaColors\>\""}], ",", 
       RowBox[{"Frame", "->", "False"}], ",", 
       RowBox[{"ImageSize", "->", "150"}], ",", 
       RowBox[{"PlotLabel", "->", "#2"}]}], "]"}], "&"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"recons", ",", "pattern"}], "]"}], ",", 
      RowBox[{"Append", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\"\<\[Chi] = \>\"", "<>", 
            RowBox[{"ToString", "[", "#", "]"}]}], "&"}], ")"}], "/@", 
         "ranks"}], ",", "\"\<exact\>\""}], "]"}]}], "}"}]}], "]"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.992414688216976*^9, 3.992414717352705*^9}},
 CellLabel->"In[1]:=",
 CellID->331172402,ExpressionUUID->"294ae299-3691-9146-bf4b-2b8409c50c10"],

