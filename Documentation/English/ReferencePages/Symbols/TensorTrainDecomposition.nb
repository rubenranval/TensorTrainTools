   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9a792fc3-c735-0c4b-ac5c-8b2707e6f9c7"],
 " to convert exact inputs to machine precision for faster execution:"
}], "ExampleText",
 CellChangeTimes->{3.992414400615671*^9},
 CellID->668466764,ExpressionUUID->"f0d4af46-eacd-7442-a369-b779b1c4ad9f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ttFast", " ", "=", " ", 
    RowBox[{"TensorTrainDecomposition", "@", 
     RowBox[{"N", "@", "exactTensor"}]}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
