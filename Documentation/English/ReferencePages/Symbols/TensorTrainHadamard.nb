Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainHadamard", "ObjectName",
 CellID->235691602,ExpressionUUID->"b7e9cdbd-a1fe-c849-ac44-31e46616ed9e"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"74d06da2-e3a8-824c-acf6-acf261edf159"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainHadamard",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainHadamard"], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["2", "TR"]], ",", " ", "\[Ellipsis]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"e40f0426-791d-db43-8dc7-1728ce156ee7"],
 "\[LineSeparator]gives the elementwise (Hadamard) product of the tensor \
trains ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["t", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FormatType->StandardForm,ExpressionUUID->
  "74dc14f7-b1af-c549-a9fe-faad224260a2"]
}], "Usage",
 CellChangeTimes->{{3.9924162005998726`*^9, 3.9924162015377483`*^9}, {
  3.9933845291313534`*^9, 3.9933846073247833`*^9}},
 CellID->318938910,ExpressionUUID->"7f7b687c-bde6-9941-92e9-3e7039ee322d"],

Cell["\<\
The product is exact: cores are combined by Kronecker products of the bond \
spaces, so the bond dimensions of the result are the products of the \
operands' bond dimensions.\
\>", "Notes",
 CellChangeTimes->{3.9933698116177864`*^9},
 CellID->954852618,ExpressionUUID->"fa1aa606-987e-7645-8c98-8d08c5f7d95c"],

Cell[TextData[{
 "Bond growth is therefore multiplicative. Compress with ",
 Cell[BoxData[
  ButtonBox["TensorTrainCompress",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress"]], 
  "InlineFormula",ExpressionUUID->"9f7b93ee-86bf-1d45-9086-50b2a5a42a7c"],
 " when chaining products to reduce the overall bond dimension."
}], "Notes",
 CellChangeTimes->{{3.993369819625078*^9, 3.993369840387127*^9}, 
   3.9933846055963097`*^9},
 CellID->701901505,ExpressionUUID->"c67cf482-0e9d-f849-a38e-57cfedc6a317"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     RowBox[{"1", " "}]], "\[CircleDot]", " ", 
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["2", "TR"]]}], "\[Ellipsis]"}]], "InlineFormula",ExpressionUUID->
  "824ccd51-2041-e846-94e7-0144dc2751bb"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainHadamard",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainHadamard"], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["1", "TR"]], ",", " ", 
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["2", "TR"]], ",", " ", "\[Ellipsis]"}], "]"}]], "InlineFormula",
  ExpressionUUID->"fbd02808-ebf7-9c45-be78-e43c801ffb5d"],
 "."
}], "Notes",
 CellChangeTimes->{{3.9933698505973015`*^9, 3.9933699193134346`*^9}, {
   3.9933845987216015`*^9, 3.9933846182846985`*^9}, 3.993389768859827*^9},
 CellID->4489167,ExpressionUUID->"6c993794-4504-0a46-9277-feb2c99fea9c"]
}, Open  ]],

