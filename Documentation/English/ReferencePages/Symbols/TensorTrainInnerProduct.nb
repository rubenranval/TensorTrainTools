Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainInnerProduct", "ObjectName",
 CellID->287724710,ExpressionUUID->"0a96224e-eea5-654a-8351-1e99ac2ec6fd"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"396855f8-b167-db4f-bd9b-3e0cc5b0d5d6"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainInnerProduct",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanvalTensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "08d889b8-7bd6-7840-92fe-161325197ada"],
 "\[LineSeparator]gives the inner product <a|b> = ",
 Cell[BoxData[
  ButtonBox["Sum",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "4d9352b7-0fa7-b848-af12-df713ea3c46d"],
 " conj(a[i]) b[i] of two tensor trains representing tensors of the same \
dimensions,contracted without forming the dense tensors. It is \
conjugate-linear in the first argument,and \n",
 Cell["   ", "ModInfo",ExpressionUUID->"c93c9aeb-61ca-b048-b1af-8eff90d8d7d5"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainInnerProduct",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanvalTensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["a", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "e6c28a5c-08bb-8540-b5e0-6e28d5440e99"],
 "\[LineSeparator]equals ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainNorm",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrainNorm"], "[", 
   StyleBox["a", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "0f6df3da-09e5-b347-92b6-376c149f8a83"],
 "^2."
}], "Usage",
