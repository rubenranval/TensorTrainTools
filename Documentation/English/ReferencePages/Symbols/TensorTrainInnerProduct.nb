Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainInnerProduct", "ObjectName",
 CellID->287724710,ExpressionUUID->"0a96224e-eea5-654a-8351-1e99ac2ec6fd"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"396855f8-b167-db4f-bd9b-3e0cc5b0d5d6"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainInnerProduct",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanvalTensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "08d889b8-7bd6-7840-92fe-161325197ada"],
 "\[LineSeparator]gives the inner product of the tensors represented by the \
tensor trains ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",ExpressionUUID->
  "26ffeb85-ce4e-374a-9b29-13c3ec0c95f5"],
 " and ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",ExpressionUUID->
  "ebc6a3c9-c197-9342-bfdc-8dfcb0748a87"]
}], "Usage",
 CellChangeTimes->{{3.9924162005998726`*^9, 3.9924162015377483`*^9}, {
  3.993384866647421*^9, 3.9933849066269093`*^9}},
 CellID->318938910,ExpressionUUID->"772d4f64-3ac1-d047-b836-46872577bc42"],

Cell["\<\
The inner product is computed by contracting all tensor indices.\
\>", "Notes",
 CellChangeTimes->{{3.9933849031450005`*^9, 3.9933849038883667`*^9}},
 CellID->8763854,ExpressionUUID->"d80d3f48-5c8e-384d-aae1-57a53ca4e475"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["TensorTrainInnerProduct",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainInnerProduct"]], 
  "InlineFormula",ExpressionUUID->"e739312f-1e1d-044c-b4bb-ae3736173324"],
 " is conjugate-linear in the first argument and linear in the second. For \
real tensor trains this coincides with the plain Euclidean inner product."
}], "Notes",
 CellChangeTimes->{{3.9933849376193066`*^9, 3.993384952967554*^9}},
 CellID->473134335,ExpressionUUID->"5c16defa-2bfd-2646-affe-96f200544b07"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainInnerProduct",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", " ", 
    StyleBox["a", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "8f27dd52-01df-7a49-b93e-168e37dbbddd"],
 " gives the squared Frobenius norm of the represented tensor."
}], "Notes",
 CellChangeTimes->{{3.993384966890009*^9, 3.9933849804171734`*^9}},
 CellID->22030749,ExpressionUUID->"4812ebcf-8750-8d4a-bbbd-cf983d4d52de"]
}, Open  ]],

