Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainNorm", "ObjectName",
 CellID->209388222,ExpressionUUID->"ed8da11b-238b-ad4e-9276-0406af23acb0"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"bc95f1e9-ae0b-794f-b203-2a1b55d6fe2a"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainNorm",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainNorm"], "[", 
   StyleBox["tt", "TI"], 
   StyleBox["]", "TI"]}]], "InlineFormula",ExpressionUUID->
  "97874257-1550-444e-8fef-d9767d3ff3a6"],
 "\[LineSeparator]gives the Frobenius norm of the tensor represented by the \
tensor train ",
 Cell[BoxData[
  StyleBox["tt", "TI"]], "InlineFormula",ExpressionUUID->
  "5213bc0c-0a03-784d-8a9b-1f70182cf9f1"]
}], "Usage",
 CellChangeTimes->{
  3.992416203525547*^9, {3.9933878147756023`*^9, 3.9933878664367867`*^9}},
 CellID->227618007,ExpressionUUID->"8afcc142-1635-e545-b441-bf219256e7a7"],

Cell["\<\
The norm is computed without forming the dense tensor: the train is \
left-orthogonalized, after which the norm equals the Euclidean norm of the \
single non-orthonormal core.\
\>", "Notes",
 CellChangeTimes->{3.993387877399763*^9},
 CellID->311988090,ExpressionUUID->"ea90e5b6-c66c-d741-a0b4-b2e37253f820"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainNorm",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrainNorm"], "[", 
   StyleBox["tt", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "f8dffb37-1a78-464f-b8cc-29f7b575afe7"],
 " produce the same result up to the rounding error as ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Sqrt",
    BaseStyle->"Link"], "[", 
   RowBox[{
    ButtonBox["TensorTrainInnerProduct",
     BaseStyle->"Link",
     ButtonData->
      "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
    RowBox[{
     StyleBox["tt", "TI"], ",", 
     StyleBox["tt", "TI"]}], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "955370a9-8450-bf4d-837b-291bd8f167a0"],
 "."
}], "Notes",
 CellChangeTimes->{{3.9933879272143326`*^9, 3.993388001186329*^9}, {
  3.993388174144953*^9, 3.993388175495634*^9}},
 CellID->103330836,ExpressionUUID->"49b05618-fb39-a44f-85df-bd914a513b83"]
}, Open  ]],

