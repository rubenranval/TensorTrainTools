Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainNorm", "ObjectName",
 CellID->209388222,ExpressionUUID->"ed8da11b-238b-ad4e-9276-0406af23acb0"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"bc95f1e9-ae0b-794f-b203-2a1b55d6fe2a"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainNorm",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainNorm"], "[", 
   ButtonBox["TensorTrain",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"], 
   "]"}]], "InlineFormula",ExpressionUUID->
  "97874257-1550-444e-8fef-d9767d3ff3a6"],
 "\[LineSeparator]gives the Frobenius (Euclidean) norm of the tensor \
represented by the tensor train ",
 Cell[BoxData[
  ButtonBox["TensorTrain",
   BaseStyle->"Link",
   ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrain"]], 
  "InlineFormula",ExpressionUUID->"c5186605-a078-174d-aac6-f89e0efb7346"],
 ", computed by left-orthogonalizing and taking the norm of the single \
remaining core, without forming the dense tensor. The result is real and \
non-negative even for complex-valued trains."
}], "Usage",
 CellChangeTimes->{3.992416203525547*^9},
 CellID->227618007,ExpressionUUID->"8afcc142-1635-e545-b441-bf219256e7a7"],

Cell["XXXX", "Notes",
 CellID->311988090,ExpressionUUID->"ea90e5b6-c66c-d741-a0b4-b2e37253f820"]
}, Open  ]],

