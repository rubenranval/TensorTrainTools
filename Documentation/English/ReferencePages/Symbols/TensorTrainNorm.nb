 "This gives the same result as ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Sqrt",
    BaseStyle->"Link"], "[", 
   RowBox[{
    ButtonBox["TensorTrainInnerProduct",
     BaseStyle->"Link",
     ButtonData->
      "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainInnerProduct"], "[", 
    RowBox[{
     StyleBox["tt", "TI"], ",", 
     StyleBox["tt", "TI"]}], "]"}], "]"}]], "InlineFormula",ExpressionUUID->
  "ba1a1b3d-29bb-f546-9738-3e3203459372"],
