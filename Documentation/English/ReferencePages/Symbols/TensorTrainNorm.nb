Cell["Get the norm of a random tensor train:", "ExampleText",
 CellChangeTimes->{{3.993388023729662*^9, 3.9933880326038094`*^9}},
 CellID->359381137,ExpressionUUID->"c7515510-e9dc-5541-81bf-55c0f84f002c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"TensorTrainDecomposition", "[", 
    RowBox[{"RandomReal", "[", 
     RowBox[{"1", ",", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TensorTrainNorm", "[", "tt", "]"}]}], "Input",
 CellChangeTimes->{{3.9933880353938656`*^9, 3.9933880643736744`*^9}},
 CellLabel->"In[5]:=",
 CellID->109145539,ExpressionUUID->"e418fa2a-3b3f-5547-95bd-44fd0735dc2e"],

