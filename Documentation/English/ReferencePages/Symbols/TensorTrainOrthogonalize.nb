Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainOrthogonalize", "ObjectName",
 CellID->50671746,ExpressionUUID->"f1a4a64c-06d8-b247-8345-35aae6849ab1"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"029e7a20-6077-f445-b548-f9e1ab790854"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainOrthogonalize",
    BaseStyle->"Link",
    ButtonData->
     "paclet:RubenRanvalTensorTrainTools/ref/TensorTrainOrthogonalize"], "[", 
   StyleBox["tt", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "25ca2f63-8277-ec45-949f-6fc8247318ed"],
 "\[LineSeparator]gives a tensor train representing the same tensor as ",
 Cell[BoxData[
  StyleBox["tt", "TI"]], "InlineFormula",ExpressionUUID->
  "1d3b1998-6a82-c040-b510-185022682247"],
 " with all cores but the last in left-orthonormal form"
}], "Usage",
 CellChangeTimes->{
  3.9924162054661083`*^9, {3.9933873520521297`*^9, 3.9933874139432373`*^9}},
 CellID->368863698,ExpressionUUID->"ba6e6755-dd88-7b47-9ddf-e26e4325d684"],

Cell[TextData[{
 "Orthogonalization does not change the represented tensor, only the gauge of \
the cores: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Normal",
     BaseStyle->"Link"], "[", 
    RowBox[{"TensorTrainOrthogonalize", "[", 
     StyleBox[
      ButtonBox["tt",
       BaseStyle->"Link",
       ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/tt"], "TI"], 
     "]"}], "]"}], " ", "==", " ", 
   RowBox[{
    ButtonBox["Normal",
     BaseStyle->"Link"], "[", 
    StyleBox[
     ButtonBox["tt",
      BaseStyle->"Link",
      ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/tt"], "TI"], 
    "]"}]}]], "InlineFormula",ExpressionUUID->
  "8a7d6c39-20dc-1348-8482-2b16cc92f37f"],
 " up to rounding."
}], "Notes",
 CellChangeTimes->{{3.993387451431263*^9, 3.9933874695239944`*^9}},
 CellID->58229255,ExpressionUUID->"04c89397-1b0d-5641-bf25-5f1b1b76d6f7"],

Cell["The following options can be given: ", "Notes",
 CellID->414257972,ExpressionUUID->"86b86f7c-8984-e146-a065-0004f29430cb"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "fc4364fb-aba9-9c47-92f9-bc7582a45ccd"], "\"\<Direction\>\"", "\"\<Right\
\>\"", Cell[
    "puts all cores but the first in right-orthonormal form", "TableText",
     ExpressionUUID->"9d33da14-c932-904a-a133-6113f6ebc687"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.9933874175721664`*^9, 3.9933874293468323`*^9}},
 CellID->370906447,ExpressionUUID->"bb17d0db-772e-df44-bde1-0b7c87f3832a"],

Cell["\<\
Orthogonalization can reduce bond dimensions: any bond larger than the \
maximal achievable rank at that position is shrunk by the QR factorization.\
\>", "Notes",
 CellChangeTimes->{{3.993387500952217*^9, 3.99338750198106*^9}},
 CellID->291736133,ExpressionUUID->"da3f92f7-ccc8-e04e-9c88-e4a62b013d93"]
}, Open  ]],

