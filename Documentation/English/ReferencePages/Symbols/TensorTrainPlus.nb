Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainPlus", "ObjectName",
 CellID->11831796,ExpressionUUID->"c30ba633-5453-394b-8bca-156041af91c5"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"e5c2a155-ebc6-4e41-8a57-bb74085967a1"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainPlus",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainPlus"], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["2", "TR"]], ",", "\[Ellipsis]"}], "]"}]], "InlineFormula",
  InitializationCell->True,ExpressionUUID->
  "afc4a5b3-4d89-c84a-840b-64f44bb92ddd"],
 "\[LineSeparator]gives the sum of the tensor trains ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["t", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",ExpressionUUID->
  "e62aef54-f4b0-5045-9cb4-32a55d49d2ab"]
}], "Usage",
 CellChangeTimes->{{3.9924162067946014`*^9, 3.9924162070066566`*^9}, {
  3.9933668927895184`*^9, 3.99336697372394*^9}, {3.993389269844843*^9, 
  3.9933892720716343`*^9}},
 CellID->349697831,ExpressionUUID->"0bf902c8-01db-cc46-b7ad-d17c636dc72e"],

Cell["All arguments must represent tensors of the same dimensions.", "Notes",
 CellChangeTimes->{{3.9933669969705696`*^9, 3.9933669980472717`*^9}, {
  3.993389290970995*^9, 3.993389292812723*^9}},
 CellID->7151323,ExpressionUUID->"fea5c786-9140-b04a-ad8e-c84894643ce9"],

Cell[TextData[{
 "The sum is exact: cores are combined block-diagonally, so the bond \
dimensions of the result are the sums of the operands' bond dimensions. Use ",
 Cell[BoxData[
  ButtonBox["TensorTrainCompress",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress"]], 
  "InlineFormula",ExpressionUUID->"6b7819d3-0503-9b48-bea5-a83dea47afb9"],
 " to reduce the ranks of the result."
}], "Notes",
 CellChangeTimes->{{3.9933669969705696`*^9, 3.993367035357094*^9}, 
   3.993389294560652*^9},
 CellID->38667900,ExpressionUUID->"33988822-1c10-3244-8637-b9542103e3e7"],

Cell["\<\
Arguments can be tensor trains or raw core lists. Core lists are converted \
automatically into tensor trains.\
\>", "Notes",
 CellChangeTimes->{{3.9933669969705696`*^9, 3.99336704036981*^9}, {
  3.993389296021904*^9, 3.993389324139677*^9}},
 CellID->174620611,ExpressionUUID->"29e38c25-38fd-0746-82f2-645509c4ceb0"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["t", "TI"], "1"], "+", 
   SubscriptBox[
    StyleBox["t", "TI"], "2"], "+", "\[Ellipsis]"}]], "InlineFormula",
  ExpressionUUID->"12b044a5-f554-214c-8374-0a5871d979c3"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainPlus",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanval/TensorTrainTools/ref/TensorTrainPlus"], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["1", "TR"]], ",", " ", 
    RowBox[{
     SubscriptBox[
      StyleBox["t", "TI"], 
      RowBox[{"2", ",", " "}]], "\[Ellipsis]"}]}], "]"}]], "InlineFormula",
  ExpressionUUID->"08a89238-1570-ce4a-8c3e-fddf9e678c67"],
 ". "
}], "Notes",
 CellChangeTimes->{{3.9933669969705696`*^9, 3.9933671010328083`*^9}, {
  3.993389278723692*^9, 3.993389287095722*^9}, {3.993389328387724*^9, 
  3.9933893301471195`*^9}},
 CellID->136859498,ExpressionUUID->"4b9aa726-e708-e74f-9c81-d09ce60598cd"]
}, Open  ]],

