Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainPlus", "ObjectName",
 CellID->11831796,ExpressionUUID->"c30ba633-5453-394b-8bca-156041af91c5"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"e5c2a155-ebc6-4e41-8a57-bb74085967a1"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainPlus",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainPlus"], "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "afc4a5b3-4d89-c84a-840b-64f44bb92ddd"],
 "\[LineSeparator]gives the tensor train representing the sum of the tensors ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",ExpressionUUID->
  "d5434234-1235-514c-9713-44c1cebedd4c"],
 " and ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",ExpressionUUID->
  "b9e92d5e-e35f-8c47-bcfe-18bbd4826d39"],
 ", which must have the same dimensions. The cores are stacked \
block-diagonally, so the bond dimensions add."
}], "Usage",
 CellChangeTimes->{{3.9924162067946014`*^9, 3.9924162070066566`*^9}},
 CellID->349697831,ExpressionUUID->"0bf902c8-01db-cc46-b7ad-d17c636dc72e"],

