 CellID->25313002,ExpressionUUID->"2270b60f-ca3b-0c4c-9641-cca9fe33fff4"],

Cell["\<\
The scalar is absorbed into the first core, all other cores and all bond \
dimensions are unchanged.\
\>", "Notes",
 CellChangeTimes->{
  3.9933696138455944`*^9, {3.9933701749018993`*^9, 3.9933701758439255`*^9}},
 CellID->51217028,ExpressionUUID->"f2c8c5df-082f-714e-982c-62985ce2b62a"],

Cell[TextData[{
