 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainScale",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainScale"], "[", 
   RowBox[{
