  "9ec4d9a2-4937-f84f-ad3d-c114807bd6cd"],
 "\[LineSeparator]gives the tensor train representing ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "1144f5a7-7a2c-0041-b818-c99246fff29f"],
 " times the tensor train ",
 Cell[BoxData[
  StyleBox["tt", "TI"]], "InlineFormula",ExpressionUUID->
  "6c8be673-5204-2442-8d11-14627c7a89ac"],
 ", for a scalar ",
