Notebook[{

Cell[CellGroupData[{
Cell["TensorTrainScale", "ObjectName",
 CellID->75870541,ExpressionUUID->"6e53bd9d-c261-f744-82c8-00488b0ae6b6"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"2e4e729f-093b-f246-b8e7-731a6b746527"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["TensorTrainScale",
    BaseStyle->"Link",
    ButtonData->"paclet:RubenRanvalTensorTrainTools/ref/TensorTrainScale"], "[", 
   RowBox[{
    StyleBox["c", "TI"], ",", 
    StyleBox["tt", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "9ec4d9a2-4937-f84f-ad3d-c114807bd6cd"],
 "\[LineSeparator]gives the tensor train representing ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "1144f5a7-7a2c-0041-b818-c99246fff29f"],
 " times the tensor ",
 Cell[BoxData[
  StyleBox["tt", "TI"]], "InlineFormula",ExpressionUUID->
  "6c8be673-5204-2442-8d11-14627c7a89ac"],
 ", for a scalar ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "36e93b01-d15a-bc41-814d-7bf01420fcd1"],
 ", by scaling a single core. The bond dimensions are unchanged."
}], "Usage",
 CellChangeTimes->{{3.9924162082325306`*^9, 3.9924162084717255`*^9}},
 CellID->25313002,ExpressionUUID->"2270b60f-ca3b-0c4c-9641-cca9fe33fff4"],

