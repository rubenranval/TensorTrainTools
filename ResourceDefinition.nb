 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "LongDescription"},
 DefaultNewCellStyle->"Text",
 CellTags->{"Basic Description", "LongDescription", "TemplateCellGroup"},
 CellLabel->"In[2]:=",
 CellID->97826971,ExpressionUUID->"7df0b0d1-55f9-9c44-b6bb-34b6271c4389"],

Cell["\<\
TensorTrainTools provides a compact Tensor Train representation for high-rank \
tensors, together with the standard operations of the tensor-train toolkit: \
decomposition of dense arrays with controlled truncation, rank compression, \
orthogonalization, norms and inner products computed without ever forming the \
dense tensor, and exact tensor arithmetic through familiar operators. A \
tensor with millions or billions of entries whose content is structured is \
often representable by a few thousand parameters. This paclet lets you find \
that representation, verify its accuracy, and keep computing inside it.\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.993393666461956*^9, 3.993393771963585*^9}},
 CellTags->"DefaultContent",
 CellID->312061637,ExpressionUUID->"4e55546d-a514-a148-95ad-6b6128ed42f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Details",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"Details", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Details may include a long description of the resource's contents, \
history, methodology or other relevant information. Give references here if \
they are directly relevant to the resource. The details will appear above the \
examples on the webpage for the resource.", "MoreInfoText"], Background -> 
        GrayLevel[0.95], FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], 
        RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoDetails"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
