     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "ddee5cdc-bdd6-e644-8c9a-25236ae8ce09"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "Details"},
 DefaultNewCellStyle->"Notes",
 CellTags->{"Details", "TemplateCellGroup"},
 CellLabel->"In[1]:=",
 CellID->280804237,ExpressionUUID->"22610513-8790-c648-8aa9-8fb3c34cc3dd"],

Cell["\<\
A tensor train represents a rank-d tensor as a chain of d rank-3 cores. \
Storage scales as O(d\[CenterDot]n\[CenterDot]\[Chi]\.b2) in the bond \
dimension \[Chi] instead of O(n\:1d48).\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.993393795176794*^9, 3.9933938004536247`*^9}},
 CellTags->"DefaultContent",
 CellID->741278932,ExpressionUUID->"b31f6781-824b-4841-9586-6c867fc42e03"],

Cell[TextData[{
 "Standard operators work directly on tensor trains: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["1", "TR"]], "+", 
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["2", "TR"]]}]], "InlineFormula",ExpressionUUID->
  "d1f8c524-bd87-7e40-9864-3c1b1c939019"],
 ", ",
 Cell[BoxData[
  StyleBox["ct", "TI"]], "InlineFormula",ExpressionUUID->
  "11358290-a0d5-3c41-950c-ca4b29e35f7c"],
 " (multiplication by a scalar ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "12205495-4b69-4741-9396-37b78128dba2"],
 "), ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["1", "TR"]], "-", 
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["2", "TR"]]}]], "InlineFormula",ExpressionUUID->
  "3dca845d-c6a8-5447-8881-5d76223ed45f"],
 ", and the elementwise product (also known as Hadamard product) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], "1"], "\[CircleDot]", " ", 
    SubscriptBox[
     StyleBox["t", "TI"], "2"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"f2ea4fbd-24d0-2a4d-bdd0-50a798366230"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.993393843190859*^9, 3.9933939715378723`*^9}, {
  3.993394148487606*^9, 3.9933941555581627`*^9}},
 CellID->380695334,ExpressionUUID->"617e5238-82ac-6040-bd0e-f8c3f0b747ab"],

Cell[TextData[{
 "Arithmetic is exact and grows bond dimensions (sums add ranks, Hadamard \
product multiply them). Using ",
 Cell[BoxData[
  ButtonBox["TensorTrainCompress",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress"]], 
  "InlineFormula",ExpressionUUID->"1c1c6230-f563-b24e-8823-3aa010633fc4"],
 " allows the reduce bond dimension after each operation."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9933939924797096`*^9, 3.9933940267553234`*^9}},
 CellID->101760473,ExpressionUUID->"0bfb84c9-888f-1e4d-9761-9988c7f66f80"]
}, Open  ]],

