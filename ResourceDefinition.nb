Cell[CellGroupData[{

Cell[TextData[{
 "Basic Description",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"LongDescription", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Give a short paragraph explaining your paclet. This is the first \
text that users will see when visiting the main landing page of your paclet.",
          "MoreInfoText"], Background -> GrayLevel[0.95], FrameMargins -> 20, 
        FrameStyle -> GrayLevel[0.9], RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoLongDescription"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "60dff4b6-48ea-7544-a676-0a1cc36115d9"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "LongDescription"},
 DefaultNewCellStyle->"Text",
 CellTags->{"Basic Description", "LongDescription", "TemplateCellGroup"},
 CellLabel->"In[2]:=",
 CellID->97826971,ExpressionUUID->"7df0b0d1-55f9-9c44-b6bb-34b6271c4389"],

Cell["\<\
TensorTrainTools provides a compact Tensor Train representation for high-rank \
tensors, together with the standard operations of the tensor-train toolkit: \
decomposition of dense arrays with controlled truncation, rank compression, \
orthogonalization, norms and inner products computed without ever forming the \
dense tensor, and exact tensor arithmetic through familiar operators. A \
tensor with millions or billions of entries whose content is structured is \
often representable by a few thousand parameters. This paclet lets you find \
that representation, verify its accuracy, and keep computing inside it.\
\>", "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.993393666461956*^9, 3.993393771963585*^9}},
 CellTags->"DefaultContent",
 CellID->312061637,ExpressionUUID->"4e55546d-a514-a148-95ad-6b6128ed42f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Details",
 Cell[BoxData[
  PaneSelectorBox[{True->
   TemplateBox[{"Details", 
     Cell[
      BoxData[
       FrameBox[
        Cell[
        "Details may include a long description of the resource's contents, \
history, methodology or other relevant information. Give references here if \
they are directly relevant to the resource. The details will appear above the \
examples on the webpage for the resource.", "MoreInfoText"], Background -> 
        GrayLevel[0.95], FrameMargins -> 20, FrameStyle -> GrayLevel[0.9], 
        RoundingRadius -> 5, ImageSize -> {
          Scaled[0.65], Automatic}]], "MoreInfoText", Deletable -> True, 
      CellTags -> {"SectionMoreInfoDetails"}, 
      CellMargins -> {{66, 66}, {15, 15}}]},
    "MoreInfoOpenerButtonTemplate"]}, Dynamic[
    CurrentValue[
     EvaluationNotebook[], {TaggingRules, "ResourceCreateNotebook"}]],
   ImageSize->Automatic]],ExpressionUUID->
  "ddee5cdc-bdd6-e644-8c9a-25236ae8ce09"]
}], "Subsection",
 Editable->False,
 Deletable->False,
 TaggingRules->{"TemplateGroupName" -> "Details"},
 DefaultNewCellStyle->"Notes",
 CellTags->{"Details", "TemplateCellGroup"},
 CellLabel->"In[1]:=",
 CellID->280804237,ExpressionUUID->"22610513-8790-c648-8aa9-8fb3c34cc3dd"],

Cell["\<\
A tensor train represents a rank-d tensor as a chain of d rank-3 cores. \
Storage scales as O(d\[CenterDot]n\[CenterDot]\[Chi]\.b2) in the bond \
dimension \[Chi] instead of O(n\:1d48).\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.993393795176794*^9, 3.9933938004536247`*^9}, 
   3.993525817171789*^9},
 CellTags->"DefaultContent",
 CellID->741278932,ExpressionUUID->"b31f6781-824b-4841-9586-6c867fc42e03"],

Cell[TextData[{
 "Standard operators work directly on tensor trains: ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["1", "TR"]], "+", 
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["2", "TR"]]}]], "InlineFormula",ExpressionUUID->
  "d1f8c524-bd87-7e40-9864-3c1b1c939019"],
 ", ",
 Cell[BoxData[
  StyleBox["ct", "TI"]], "InlineFormula",ExpressionUUID->
  "11358290-a0d5-3c41-950c-ca4b29e35f7c"],
 " (multiplication by a scalar ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",ExpressionUUID->
  "12205495-4b69-4741-9396-37b78128dba2"],
 "), ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["1", "TR"]], "-", 
   SubscriptBox[
    StyleBox["t", "TI"], 
    StyleBox["2", "TR"]]}]], "InlineFormula",ExpressionUUID->
  "3dca845d-c6a8-5447-8881-5d76223ed45f"],
 ", and the elementwise product (also known as Hadamard product) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], "1"], "\[CircleDot]", " ", 
    SubscriptBox[
     StyleBox["t", "TI"], "2"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"f2ea4fbd-24d0-2a4d-bdd0-50a798366230"],
 "."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.993393843190859*^9, 3.9933939715378723`*^9}, {
  3.993394148487606*^9, 3.9933941555581627`*^9}},
 CellID->380695334,ExpressionUUID->"617e5238-82ac-6040-bd0e-f8c3f0b747ab"],

Cell[TextData[{
 "Arithmetic is exact and grows bond dimensions (sums add ranks, Hadamard \
product multiply them). Using ",
 Cell[BoxData[
  ButtonBox["TensorTrainCompress",
   BaseStyle->"Link",
   ButtonData->
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress"]], 
  "InlineFormula",ExpressionUUID->"1c1c6230-f563-b24e-8823-3aa010633fc4"],
 " allows the reduce bond dimension after each operation."
}], "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.9933939924797096`*^9, 3.9933940267553234`*^9}, {
  3.9935262612482452`*^9, 3.9935262624212284`*^9}},
 CellID->101760473,ExpressionUUID->"0bfb84c9-888f-1e4d-9761-9988c7f66f80"],

Cell["\<\
Applications span high-dimensional PDEs, fluid dynamics, quantum many-body \
physics (where tensor train are known as matrix product states, MPS), and \
machine learning for compressing neural network layers.\
\>", "Notes",
 TaggingRules->{},
 CellChangeTimes->{{3.993526275488943*^9, 3.9935263360394573`*^9}},
 CellID->114094801,ExpressionUUID->"d229f2a2-d9c8-c649-b838-f83f1378dc6c"]
}, Open  ]],

