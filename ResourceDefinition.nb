Cell[TextData[{
 "A rank-40 tensor with 2\:2074\:2070 entries (about 8 TB dense) can be held \
in a few thousand parameters, with its norm computed directly in the \
compressed format. Here we are generating a random tensor train representing \
a tensor of dimensions ",
 Cell[BoxData[
  RowBox[{
  "2", " ", "\[Cross]", " ", "2", " ", "\[Cross]", " ", "\[Ellipsis]", " ", "\[Cross]",
    " ", "2"}]], "InlineFormula",ExpressionUUID->
  "72223064-b151-ca4e-8b29-8879ff86b791"],
 " with max bond dimensions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
   "2", ",", " ", "4", ",", " ", "4", ",", " ", "\[Ellipsis]", ",", " ", "4", 
    ",", " ", "2"}], "}"}]], "InlineFormula",ExpressionUUID->
  "ab82a1ae-29fa-c64e-9d9e-2c7ece63b41b"],
 ":"
}], "ExampleText",
 TaggingRules->{},
 CellChangeTimes->{{3.993394868816635*^9, 3.993394891215084*^9}, {
  3.9933975211216507`*^9, 3.9933975378850327`*^9}, {3.993397579033331*^9, 
  3.9933976907042484`*^9}},
 CellID->411843840,ExpressionUUID->"bddf8589-8876-fb44-9b0b-e4d88590d36b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"big", "=", 
  RowBox[{"RandomTensorTrain", "[", 
   RowBox[{
    RowBox[{"ConstantArray", "[", 
     RowBox[{"2", ",", "40"}], "]"}], ",", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"{", "2", "}"}], ",", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"4", ",", "37"}], "]"}], ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9933972209516945`*^9, 3.9933972262103004`*^9}, {
   3.9933972883980026`*^9, 3.9933972960068665`*^9}, 3.993397510778799*^9, {
