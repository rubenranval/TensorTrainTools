Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t", "=", 
   RowBox[{"N", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"x", "+", "y", "+", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "20"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "20"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "20"}], "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"tt", "=", 
  RowBox[{"TensorTrainDecomposition", "[", 
   RowBox[{"t", ",", 
    RowBox[{"Tolerance", "->", 
     SuperscriptBox["10", 
      RowBox[{"-", "10"}]]}]}], "]"}]}], "\n"}], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.993394204873312*^9, 3.9933942334896927`*^9}},
 CellTags->"DefaultContent",
