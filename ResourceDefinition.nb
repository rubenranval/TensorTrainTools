Cell[TextData[{
 "Decompose a structured tensor ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",ExpressionUUID->
  "11efd85a-c2f9-304b-acb3-5a03b8e41e2a"],
 " into a tensor train ",
 Cell[BoxData[
  StyleBox["tt", "TI"]], "InlineFormula",ExpressionUUID->
  "fafc0eea-878f-844b-a4d7-a850c35970c6"],
 ":"
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.9933941916095066`*^9, 3.9933942502519035`*^9}},
 CellTags->"DefaultContent",
 CellID->489008670,ExpressionUUID->"8e92dcc5-a8e5-a147-8356-1276d26735c8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t", "=", 
   RowBox[{"N", "@", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"x", "+", "y", "+", "z"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "20"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "20"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "20"}], "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"tt", "=", 
  RowBox[{"TensorTrainDecomposition", "[", 
   RowBox[{"t", ",", 
    RowBox[{"Tolerance", "->", 
     SuperscriptBox["10", 
      RowBox[{"-", "10"}]]}]}], "]"}]}], "\n"}], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.993394204873312*^9, 3.9933942334896927`*^9}},
 CellTags->"DefaultContent",
 CellLabel->"In[1]:=",
