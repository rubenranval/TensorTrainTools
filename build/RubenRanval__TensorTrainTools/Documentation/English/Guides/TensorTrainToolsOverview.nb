Cell[CellGroupData[{

Cell["TensorTrainTools Overview", "GuideTitle",
 CellID->27779272,ExpressionUUID->"8cbb7c07-7426-0d4c-af8a-9e779887cc7a"],

Cell["\<\
Tensor trains represent high-rank tensors as chains of small cores, turning \
exponentially large arrays into a compact format that supports decomposition, \
compression, and arithmetic. The functions fall into a few natural groups: \
construction, conversion to and from dense arrays, rank control and \
arithmetic.\
\>", "GuideAbstract",
 CellID->107535106,ExpressionUUID->"2a3f5f77-ae45-da41-9fb7-e4d09ba6a1d8"],

