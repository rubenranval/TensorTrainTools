Cell[TextData[{
 "A tensor train (also called a matrix product state, MPS) expresses a tensor \
of rank ",
 Cell[BoxData["n"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1ed5c796-cbe2-7f4f-8546-b420bccc80ed"],
 " as a chain of ",
 Cell[BoxData["n"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9df4e0fd-9f6d-9342-8033-84e8b1569f5c"],
 " rank-3 cores, typically storing far fewer elements than the dense tensor."
}], "Notes",
 CellID->320248012,ExpressionUUID->"770d44e6-9515-a849-bbef-c249c96903d4"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  SubscriptBox["A", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "25fce1bc-69ad-4143-a49d-e6a378ac32f7"],
 " must be a rank-3 array with dimensions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox["\[Chi]", 
     RowBox[{"i", "-", "1"}]], ",", 
    SubscriptBox["n", "i"], ",", 
    SubscriptBox["\[Chi]", "i"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "271929d7-dfbb-1942-b81f-191e33cecd5f"],
 ", where ",
 Cell[BoxData[
  SubscriptBox["n", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ea8ecd15-33c7-5e4f-a0f2-31c332c941bc"],
 " is the ",
 Cell[BoxData[
  SuperscriptBox["i", "th"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "73848381-d564-7149-b700-1a69cdc26e46"],
 " dimension of the represented tensor and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f3cff80e-d665-104f-a077-6c31c7abb1d9"],
 " are the bond dimensions."
}], "Notes",
 CellID->23113461,ExpressionUUID->"ffa41cfb-63f3-bc4e-a32b-4b9ba026a3b7"],

Cell[TextData[{
 "The boundary bond dimensions ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "0"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ae0526dc-9ae3-f74c-82d3-e4d696032ad6"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "n"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f1f05ebb-7c65-1541-bbcc-b6b01b59372a"],
 " must both equal 1, and the last dimension of each core must equal the \
first dimension of the following core."
}], "Notes",
 CellID->276603418,ExpressionUUID->"63ac948a-cb44-a54c-97d5-381867aca893"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrain"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrain", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32815445-6f20-904c-843a-02933eebf0d2"],
 " validates its cores, issuing a message and returning ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$Failed"]], "paclet:ref/$Failed"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "73c4683f-a771-7b49-9b3a-1c672f86690a"],
 " if they do not form a valid tensor train."
}], "Notes",
 CellID->172931060,ExpressionUUID->"e655fdf6-485c-8947-b074-4f86321db930"],

