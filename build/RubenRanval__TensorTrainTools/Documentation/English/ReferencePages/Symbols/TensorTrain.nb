Cell[TextData[{
 "A tensor train (also called a matrix product state, MPS) expresses a tensor \
of rank ",
 Cell[BoxData["n"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b772c3e8-611d-8248-99d3-d91c713a4489"],
 " as a chain of ",
 Cell[BoxData["n"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "06a88c09-043e-a145-8ca8-b8c84b2a7217"],
 " rank-3 cores, typically storing far fewer elements than the dense tensor."
}], "Notes",
 CellID->320248012,ExpressionUUID->"a1b4fe09-50f4-9344-b855-93d88daadb56"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  SubscriptBox["A", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "73c12a5e-733f-ba48-81e5-695cc1530d8a"],
 " must be a rank-3 array with dimensions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox["\[Chi]", 
     RowBox[{"i", "-", "1"}]], ",", 
    SubscriptBox["n", "i"], ",", 
    SubscriptBox["\[Chi]", "i"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c1d7c3be-2bc6-9942-8937-37744e0103a9"],
 ", where ",
 Cell[BoxData[
  SubscriptBox["n", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f66bcdd9-7a3f-fc43-a4f7-b238231c101b"],
 " is the ",
 Cell[BoxData[
  SuperscriptBox["i", "th"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b606338d-112d-3840-8c41-29ea7ff82bf0"],
 " dimension of the represented tensor and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "i"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d340a878-0459-f044-9a6c-08ca764de3e7"],
 " are the bond dimensions."
}], "Notes",
 CellID->23113461,ExpressionUUID->"76238322-45eb-ab4f-a00d-137a354c36ac"],

Cell[TextData[{
 "The boundary bond dimensions ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "0"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d01d18ff-63c6-1448-8b07-843fa594e305"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[Chi]", "n"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dc1837ad-f78b-2547-a525-4bd5fbcdf80c"],
 " must both equal 1, and the last dimension of each core must equal the \
first dimension of the following core."
}], "Notes",
 CellID->276603418,ExpressionUUID->"d6b23ea9-5783-5247-9ee2-11e8dcb53b11"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrain"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrain", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8a6611a6-21c3-2140-878d-1d5c624b8e6c"],
 " validates its cores, issuing a message and returning ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$Failed"]], "paclet:ref/$Failed"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bcc3a8b0-d3a3-3246-8827-a5e8ae363551"],
 " if they do not form a valid tensor train."
}], "Notes",
 CellID->172931060,ExpressionUUID->"cde7851b-9b40-fc40-9093-16ca4a728288"],

