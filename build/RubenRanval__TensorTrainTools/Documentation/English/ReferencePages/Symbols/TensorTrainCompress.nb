Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainCompress"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f4e48afd-af4e-154f-8764-8032d0b70a1e"],
 " implements standard TT rounding: the train is right-orthogonalized, then \
truncated by SVD in a left-to-right sweep. The orthogonal environment makes \
each local truncation optimal for its bond."
}], "Notes",
 CellID->5007822,ExpressionUUID->"7fc9cdb8-5f33-ec46-8680-9c77757f5f9a"],

Cell["\<\
With default options the represented tensor is unchanged and only redundant \
rank is removed.\
\>", "Notes",
 CellID->755125292,ExpressionUUID->"40215a5a-e043-bf45-9dd5-910e7860e3e8"]
}, Closed]],

