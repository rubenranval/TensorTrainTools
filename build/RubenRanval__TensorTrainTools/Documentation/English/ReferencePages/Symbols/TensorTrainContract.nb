Cell["\<\
Cores whose adjacent bond dimensions do not match cannot be contracted (here \
3 \[NotEqual] 4):\
\>", "ExampleText",
 CellID->608917904,ExpressionUUID->"c4fedaf3-8ee4-5144-82b7-97539f661b0c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TensorTrainContract", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"RandomReal", "[", 
     RowBox[{"1", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], ",", 
    RowBox[{"RandomReal", "[", 
     RowBox[{"1", ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "2", ",", "1"}], "}"}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[1]:=",
 CellID->87851459,ExpressionUUID->"156ab959-1ad3-324d-abd4-45907a5c4c8f"],

Cell[BoxData[
 TemplateBox[{
  "TensorTrain", "bond", 
   "\"Inconsistent bond dimensions between cores \\!\\(\\*RowBox[{\\\"1\\\"}]\
\\) and \\!\\(\\*RowBox[{\\\"2\\\"}]\\): \\!\\(\\*RowBox[{\\\"3\\\"}]\\) vs \
\\!\\(\\*RowBox[{\\\"4\\\"}]\\).\"", 2, 1, 10, 28760423683112345937, "Local", 
   "RubenRanval`TensorTrainTools`TensorTrain"},
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->"During evaluation of In[1]:=",
 CellID->123241018,ExpressionUUID->"524b15f4-cff1-f246-addb-71134baf29dc"],

Cell[BoxData["$Failed"], "Output",
 CellLabel->"Out[1]=",
 CellID->6334423,ExpressionUUID->"d55f8e78-c0bf-7c43-8dad-ee920f6e82a0"]
}, Open  ]],

Cell["\<\
The first and last cores must have boundary bond dimension 1:\
\>", "ExampleText",
 CellID->16223174,ExpressionUUID->"1ba92a04-bc81-fa44-a80d-511abd14cc34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TensorTrainContract", "[", 
  RowBox[{"{", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3", ",", "1"}], "}"}]}], "]"}], "}"}], 
  "]"}]], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[2]:=",
 CellID->920892606,ExpressionUUID->"2f1c7b6e-5f61-0940-be7f-bdcff871da44"],

Cell[BoxData[
 TemplateBox[{
  "TensorTrain", "bdry", 
   "\"Boundary bonds must both be 1, but are \\!\\(\\*RowBox[{\\\"2\\\"}]\\) \
(left) and \\!\\(\\*RowBox[{\\\"1\\\"}]\\) (right).\"", 2, 2, 11, 
   28760423683112345937, "Local", "RubenRanval`TensorTrainTools`TensorTrain"},
  
  "MessageTemplate2",
  BaseStyle->"MSG"]], "Message",
 CellLabel->"During evaluation of In[2]:=",
 CellID->998082389,ExpressionUUID->"242ae14d-2d1b-844f-a9ea-96bac884ecc3"],

