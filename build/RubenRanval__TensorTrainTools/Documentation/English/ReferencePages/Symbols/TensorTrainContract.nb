Cell[TextData[{
 Cell[BoxData["TensorTrainContract"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9888beb8-c8e7-b943-a3e9-c4a2a2fedd12"],
 " reconstructs a full dense array from its Tensor Train (TT) representation \
(also known as the Matrix Product State representation). It is the inverse of \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainDecomposition"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e44f5d31-3211-9444-85ca-71a27c6622be"],
 "."
}], "Notes",
 CellID->10691157,ExpressionUUID->"de0cba6f-fd0e-884f-884c-433df4945ba4"],

Cell[TextData[{
 "The input is a nonempty list of rank-3 arrays ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fd680f6b-675d-df4f-9443-bee76247c53b"],
 ", where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "42b50608-f3da-044b-b8e9-f5aad597e1b2"],
 " is the number of dimensions of the resulting array."
}], "Notes",
 CellID->532595843,ExpressionUUID->"66ee9376-2edb-fe46-a864-dc35000dfb59"],

Cell["\<\
The bond dimension refers to the size of the internal contracted indices \
connecting adjacent tensor cores. It effectively dictates the rank and \
compression level of the Tensor Train.\
\>", "Notes",
 CellID->362833641,ExpressionUUID->"9d6a662e-a3be-3a45-9f60-5ba9e587d5f0"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "7445d010-288d-c342-8725-b150aa7d1436"],
 " has dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Chi]", 
      RowBox[{"k", "-", "1"}]], ",", 
     SubscriptBox["d", "k"], ",", 
     SubscriptBox["\[Chi]", "k"]}], "}"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "dcf9863f-b948-e343-8424-10312b677b15"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "k"], TraditionalForm]],ExpressionUUID->
  "13fe3c4d-9ef2-9b43-8bd5-8fe5ba3d26c4"],
 " is the size of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "36ee43af-fc53-a14a-9b3c-e0465875eb51"],
 " dimension of the resulting array, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "k"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "ae3df3c9-042a-0741-9bf3-ee729b664f56"],
 " is the bond dimension between cores ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "80921c02-2bd8-1a45-8ce7-74f483740aa4"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["k", "TI"], "+", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1e1108da-a5cf-f247-9aca-486f3a6aee0f"],
 "."
}], "Notes",
 CellID->534729610,ExpressionUUID->"d56999bf-c9a9-be4d-b0fc-bce3eb47629a"],

Cell[TextData[{
 "The first core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "a92ffe9d-2586-fe44-9fe4-f2f212171f76"],
 " and the last core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "n"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "8faa5217-2cf4-c84b-bd76-fed4733dd65c"],
 "."
}], "Notes",
 CellID->57498604,ExpressionUUID->"3f1abc47-bf7d-1944-9448-2301fc55c858"],

Cell[TextData[{
 "Contracting the cores returned by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainDecomposition"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b82e47e2-6aba-ac4c-958a-6128e56b8594"],
 " reconstructs the original array, exactly up to floating-point error when \
the decomposition was exact, or up to the truncation error when a ",
 Cell[BoxData["\"\<MaxBondDimension\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d635460-b866-9d42-9005-8bbf61ec57ca"],
 " cap or nonzero ",
 Cell[BoxData[
  TagBox[
   TemplateBox[{
     Cell[
      TextData[
       StyleBox[
       "Tolerance", "SymbolsRefLink", ShowStringCharacters -> True, 
        FontFamily -> "Source Sans Pro"]]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0468023b-bb1b-ed48-97f0-de04c597c69d"],
 " was applied."
}], "Notes",
 CellID->13324534,ExpressionUUID->"e6ae7bd9-2b54-874a-bfc7-9caf54be0544"]
}, Closed]],

