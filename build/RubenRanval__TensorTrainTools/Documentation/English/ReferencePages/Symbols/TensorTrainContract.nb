Cell[TextData[{
 Cell[BoxData["TensorTrainContract"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "742c6bb4-39b5-e24d-a691-6078554fa745"],
 " reconstructs a full dense array from its Tensor Train (TT) representation \
(also known as the Matrix Product State representation). It is the inverse of \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainDecomposition"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0b5de109-e436-a54f-85f7-c50c8aaa450b"],
 "."
}], "Notes",
 CellID->10691157,ExpressionUUID->"fa25cfe3-f327-a741-80b3-3f2ce6f2a0ae"],

Cell[TextData[{
 "The input is a nonempty list of rank-3 arrays ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bc660498-ef7c-aa4b-a624-08204815c163"],
 ", where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ea395619-df6a-644b-86f2-296afd27c282"],
 " is the number of dimensions of the resulting array."
}], "Notes",
 CellID->532595843,ExpressionUUID->"bfc17533-6a11-0442-8229-2c1563ba78af"],

Cell["\<\
The bond dimension refers to the size of the internal contracted indices \
connecting adjacent tensor cores. It effectively dictates the rank and \
compression level of the Tensor Train.\
\>", "Notes",
 CellID->362833641,ExpressionUUID->"a9f0dbbd-51fc-7241-b1f2-42f9086ff387"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "3a6c2d04-9c52-a345-9e08-60eeb695fe6e"],
 " has dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Chi]", 
      RowBox[{"k", "-", "1"}]], ",", 
     SubscriptBox["d", "k"], ",", 
     SubscriptBox["\[Chi]", "k"]}], "}"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "98c04dd7-7bce-804a-82a9-21ea190ab28e"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "k"], TraditionalForm]],ExpressionUUID->
  "927cc33c-9bf8-bb48-b5df-50f76f6236d5"],
 " is the size of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "1a68ba80-f56d-1247-a5e5-40da8926d897"],
 " dimension of the resulting array, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "k"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "3cd5c18b-81f3-ba45-b845-07a44f30b597"],
 " is the bond dimension between cores ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9e9bcbda-577a-fb46-9a90-61330ddc42c5"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["k", "TI"], "+", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ed62bb08-d691-794d-a347-03401f5f9386"],
 "."
}], "Notes",
 CellID->534729610,ExpressionUUID->"49d075c4-38bb-844f-8474-df399215a3ce"],

Cell[TextData[{
 "The first core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "af999ec5-309b-324b-879b-2b08b9d83e51"],
 " and the last core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "n"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "b332ab44-00b3-d544-9f91-5f67c15ee153"],
 "."
}], "Notes",
 CellID->57498604,ExpressionUUID->"1d01683b-f780-6645-8f5c-0bdf18169052"],

Cell[TextData[{
 "Contracting the cores returned by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainDecomposition"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainDecomposition", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aeb8fb6e-165c-f849-a2d7-5b4b68222fe2"],
 " reconstructs the original array, exactly up to floating-point error when \
the decomposition was exact, or up to the truncation error when a ",
 Cell[BoxData["\"\<MaxBondDimension\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ff3d083e-6ce6-074b-a031-9f4a415caf72"],
 " cap or nonzero ",
 Cell[BoxData[
  TagBox[
   TemplateBox[{
     Cell[
      TextData[
       StyleBox[
       "Tolerance", "SymbolsRefLink", ShowStringCharacters -> True, 
        FontFamily -> "Source Sans Pro"]]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b868e413-cecf-7844-a6f5-973d5a4f67ac"],
 " was applied."
}], "Notes",
 CellID->13324534,ExpressionUUID->"66c54a75-5056-5042-aaa5-32f3254fda72"]
}, Closed]],

