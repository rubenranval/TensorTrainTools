Cell["\<\
Cores whose adjacent bond dimensions do not match cannot be contracted (here \
3 \[NotEqual] 4):\
\>", "ExampleText",
 CellID->608917904,ExpressionUUID->"86bded73-1024-c740-ac6c-9ebfcbf6445d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TensorTrainContract", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"RandomReal", "[", 
     RowBox[{"1", ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], ",", 
    RowBox[{"RandomReal", "[", 
     RowBox[{"1", ",", 
      RowBox[{"{", 
       RowBox[{"4", ",", "2", ",", "1"}], "}"}]}], "]"}]}], "}"}], 
  "]"}]], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[1]:=",
 CellID->87851459,ExpressionUUID->"1fdbb342-6442-f24b-99bf-21f221185fb9"],

Cell[BoxData[
 TemplateBox[{
  "TensorTrain", "bond", 
   "\"Inconsistent bond dimensions between cores \\!\\(\\*RowBox[{\\\"1\\\"}]\
\\) and \\!\\(\\*RowBox[{\\\"2\\\"}]\\): \\!\\(\\*RowBox[{\\\"3\\\"}]\\) vs \
\\!\\(\\*RowBox[{\\\"4\\\"}]\\).\"", 2, 1, 10, 28760423683112345937, "Local", 
   "RubenRanval`TensorTrainTools`TensorTrain"},
