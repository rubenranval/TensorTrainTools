Cell["\<\
Because contraction works on any valid train, you can decompose with a capped \
bond dimension and contract the result to obtain a low-rank approximation of \
the original tensor. The difference is the truncation error:\
\>", "ExampleText",
 CellID->669699521,ExpressionUUID->"372e7890-060b-8a4f-b159-fa14a2633bc7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"largeTensor", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "4", ",", "4", ",", "4"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"compressed", "=", 
    RowBox[{"TensorTrainDecomposition", "[", 
     RowBox[{"largeTensor", ",", 
      RowBox[{"\"\<MaxBondDimension\>\"", "->", "2"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"approx", "=", 
   RowBox[{"TensorTrainContract", "[", "compressed", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Max", "[", 
  RowBox[{"Abs", "[", 
   RowBox[{"largeTensor", "-", "approx"}], "]"}], "]"}]}], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[1]:=",
 CellID->436603722,ExpressionUUID->"730cf186-537a-e547-a909-b499c5e780ed"],

Cell[BoxData["0.6355494752145587`"], "Output",
 CellLabel->"Out[1]=",
 CellID->615655830,ExpressionUUID->"925f1ee1-d848-2341-9a3d-8dc0332db694"]
}, Open  ]]
}, Closed]],

