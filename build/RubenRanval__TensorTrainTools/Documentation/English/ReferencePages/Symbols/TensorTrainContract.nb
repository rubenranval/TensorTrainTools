Cell["\<\
The first and last cores must have boundary bond dimension 1:\
\>", "ExampleText",
 CellID->16223174,ExpressionUUID->"2943e02b-db12-d34c-b090-37589735a34a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TensorTrainContract", "[", 
  RowBox[{"{", 
   RowBox[{"RandomReal", "[", 
    RowBox[{"1", ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "3", ",", "1"}], "}"}]}], "]"}], "}"}], 
  "]"}]], "Input",
