Cell[TextData[{
 "With ",
 Cell[BoxData[
  TagBox[
   TemplateBox[{
     Cell[
      TextData[
       StyleBox[
       "Method", "SymbolsRefLink", ShowStringCharacters -> True, FontFamily -> 
