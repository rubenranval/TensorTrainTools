Cell["\<\
TensorTrainDecomposition decomposes a numerical array of any rank into a \
Tensor Train (also known as a Matrix Product State) representation.\
\>", "Notes",
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->440071331,ExpressionUUID->"6d2f3cb3-f340-3a41-895a-35178bee730f"],

Cell[TextData[{
 "The result is a list of rank-3 arrays ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["A", "1"], ",", 
     RowBox[{
      SubscriptBox["A", "2"], "\[Ellipsis]"}], ",", 
     SubscriptBox["A", 
      StyleBox["n", "TI"]]}], "}"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a8ddf98e-7d51-2344-acf6-8079952ddf63"],
 " where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d0fb1851-f179-3542-8ac5-cf5d13e018c7"],
 " is the number of dimensions of the input tensor."
}], "Notes",
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->364261975,ExpressionUUID->"7bac12a5-1745-5140-902e-7f1b6b7c497e"],

Cell["\<\
The bond dimension refers to the size of the internal contracted indices \
connecting adjacent tensor cores. It effectively dictates the rank and \
compression level of the Tensor Train.\
\>", "Notes",
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->27814531,ExpressionUUID->"6e31d62f-1987-324d-b4c5-98e1b6e35027"],

Cell[TextData[{
 "Each core ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "d32af754-fda9-fe47-8a39-92eb0018ed90"],
 " has dimensions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Chi]", 
      RowBox[{"k", "-", "1"}]], ",", 
     SubscriptBox["d", "k"], ",", 
     SubscriptBox["\[Chi]", "k"]}], "}"}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "19731b99-0cc4-454d-b5ad-a3acbd8b5895"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "k"], TraditionalForm]],ExpressionUUID->
  "e7e20f3b-3171-7c40-937b-e9a4a64052c2"],
 " is the size of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "002dac91-349f-6344-be37-03c7ac03a358"],
 " dimension of the input tensor, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Chi]", "k"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "09b728ad-f6e2-c14a-964d-4bf37edb9af6"],
 " is the bond dimension between cores k and k+1."
}], "Notes",
 InitializationCell->True,
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
       SelectedNotebook[], After, Cell]; NotebookFind[
       SelectedNotebook[], "TabNext", Next, CellTags, AutoScroll -> True, 
       WrapAround -> True], Blank[NotebookSelection] :> SelectionMove[
       SelectedNotebook[], All, CellContents, AutoScroll -> True]], 
   PassEventsDown -> False, PassEventsUp -> False},
 CellTags->{"DefaultContent", "TabNext"},
 CellID->614074359,ExpressionUUID->"447d5926-c631-004b-bd71-36a6f5e1076d"],

Cell[TextData[{
 "The first core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "26f06bc0-ded5-6549-9423-9b7505be64ae"],
 " and the last core has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Chi]", "n"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "1bdf6222-949d-d245-b691-d0ceb89bca08"],
 "."
}], "Notes",
 InitializationCell->True,
 CellEventActions->{Inherited, {"KeyDown", "\t"} :> Replace[SelectionMove[
