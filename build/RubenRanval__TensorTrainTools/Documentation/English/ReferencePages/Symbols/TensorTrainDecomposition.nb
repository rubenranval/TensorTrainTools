Cell[TextData[{
 "Use ",
 Cell[BoxData["\"\<QR\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "981efaf7-ba11-1947-b246-fdc650771753"],
 " instead of ",
 Cell[BoxData["\"\<SVD\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "eb649638-4611-8448-8c6d-60f7a7e4f270"],
 " to perform an exact transformation without truncation (note that ",
 Cell[BoxData["\"\<MaxBondDimension\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4a570478-a1cd-ad42-929c-5828aa2f18ea"],
 " and ",
 Cell[BoxData[
  TagBox[
   TemplateBox[{
     Cell[
      TextData[
       StyleBox[
       "Tolerance", "SymbolsRefLink", ShowStringCharacters -> True, 
        FontFamily -> "Source Sans Pro"]]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}],
   MouseAppearanceTag["LinkHand"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cc6be018-b6f8-7244-8753-80664cb873e2"],
 " will be ignored):"
}], "ExampleText",
 CellID->7344422,ExpressionUUID->"4c2c2913-3383-8047-a174-2b4761169210"],

