  RowBox[{"exactTensor", " ", "=", " ", 
   RowBox[{"RandomInteger", "[", 
    RowBox[{"1", ",", " ", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "3"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ttSlow", " ", "=", " ", 
    RowBox[{"TensorTrainDecomposition", "@", "exactTensor"}]}], ";"}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[1]:=",
 CellID->78693757,ExpressionUUID->"d27602b0-9b54-fa41-8359-e288ba19ebde"],

