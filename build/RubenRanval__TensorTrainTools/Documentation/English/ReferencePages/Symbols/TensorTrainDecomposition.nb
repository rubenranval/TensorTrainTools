Cell["\<\
Reconstruct a non-separable pattern from tensor trains of increasing bond \
dimension to watch a low-rank approximation sharpen into the exact array:\
\>", "ExampleText",
 CellID->294162820,ExpressionUUID->"bd777286-0ecb-6145-bf50-8504437a6b6f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", "120"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"n", "+", "1"}], ")"}], "/", "2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pattern", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sin", "[", 
      FractionBox[
       RowBox[{"Sqrt", "[", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"i", "-", "c"}], ")"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"j", "-", "c"}], ")"}], "2"]}], "]"}], "4."], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "n"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ranks", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "3", ",", " ", "5", ",", "20", ",", "30"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"recons", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"TensorTrainContract", "[", 
      RowBox[{"TensorTrainDecomposition", "[", 
       RowBox[{"pattern", ",", 
        RowBox[{"\"\<MaxBondDimension\>\"", "->", "r"}]}], "]"}], "]"}], ",", 
     
     RowBox[{"{", 
      RowBox[{"r", ",", "ranks"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Row", "[", 
  RowBox[{"MapThread", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ArrayPlot", "[", 
      RowBox[{"#1", ",", 
       RowBox[{"ColorFunction", "->", "\"\<DeepSeaColors\>\""}], ",", 
       RowBox[{"Frame", "->", "False"}], ",", 
       RowBox[{"ImageSize", "->", "150"}], ",", 
       RowBox[{"PlotLabel", "->", "#2"}]}], "]"}], "&"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Append", "[", 
       RowBox[{"recons", ",", "pattern"}], "]"}], ",", 
      RowBox[{"Append", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\"\<\[Chi] = \>\"", "<>", 
            RowBox[{"ToString", "[", "#", "]"}]}], "&"}], ")"}], "/@", 
         "ranks"}], ",", "\"\<exact\>\""}], "]"}]}], "}"}]}], "]"}], 
  "]"}]}], "Input",
 CellProlog:>Needs["RubenRanval`TensorTrainTools`"],
 CellLabel->"In[1]:=",
 CellID->331172402,ExpressionUUID->"33e04f05-03a4-4e45-a4aa-566d9e7873b8"],

