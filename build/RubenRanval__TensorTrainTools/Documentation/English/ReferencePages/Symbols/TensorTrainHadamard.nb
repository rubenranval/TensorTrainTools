Cell["\<\
The product is exact: cores are combined by Kronecker products of the bond \
spaces, so the bond dimensions of the result are the products of the \
operands' bond dimensions.\
\>", "Notes",
 CellID->954852618,ExpressionUUID->"b9bbecd2-c130-684b-848e-370f2563afe8"],

Cell[TextData[{
 "Bond growth is therefore multiplicative. Compress with ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainCompress"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54078c07-32a8-0947-8edc-2b81f148c866"],
 " when chaining products to reduce the overall bond dimension."
}], "Notes",
 CellID->701901505,ExpressionUUID->"c88ec32d-09b9-ff4a-89ac-fd89eb91b394"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["t", "TI"], 
     RowBox[{"1", " "}]], "\[CircleDot]", " ", 
    SubscriptBox[
     StyleBox["t", "TI"], 
     StyleBox["2", "TR"]]}], "\[Ellipsis]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "41b37421-f10a-aa4b-9431-4d17016b2c73"],
