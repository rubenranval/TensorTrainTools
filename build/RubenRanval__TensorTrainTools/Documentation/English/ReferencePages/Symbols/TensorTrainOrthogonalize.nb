Cell[TextData[{
 "Orthogonalization does not change the represented tensor, only the gauge of \
the cores: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Normal"]], "paclet:ref/Normal"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{"TensorTrainOrthogonalize", "[", 
     TemplateBox[{
       Cell[
        TextData["tt"]], "paclet:RubenRanval/TensorTrainTools/ref/tt"},
      "RefLink",
      BaseStyle->{"InlineFormula", "TI"}], "]"}], "]"}], " ", "==", " ", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Normal"]], "paclet:ref/Normal"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    TemplateBox[{
      Cell[
       TextData["tt"]], "paclet:RubenRanval/TensorTrainTools/ref/tt"},
     "RefLink",
     BaseStyle->{"InlineFormula", "TI"}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "91b667d6-cb13-6846-9334-c7052d6ba287"],
 " up to rounding."
}], "Notes",
