Cell["All arguments must represent tensors of the same dimensions.", "Notes",
 CellID->7151323,ExpressionUUID->"e11804f6-3df6-104f-9499-bd0e6262b67e"],

Cell[TextData[{
 "The sum is exact: cores are combined block-diagonally, so the bond \
dimensions of the result are the sums of the operands' bond dimensions. Use \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorTrainCompress"]], 
    "paclet:RubenRanval/TensorTrainTools/ref/TensorTrainCompress", 
    "RubenRanval Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "83469cbd-1da0-574b-a66d-bccb46511fb8"],
 " to reduce the ranks of the result."
}], "Notes",
 CellID->38667900,ExpressionUUID->"99ca4ae8-9dea-4f46-ab93-83f44695d3ac"],

Cell["\<\
Arguments can be tensor trains or raw core lists. Core lists are converted \
automatically into tensor trains.\
\>", "Notes",
 CellID->174620611,ExpressionUUID->"cfc7a19e-1246-d946-99b0-d9f0e690f35a"],

